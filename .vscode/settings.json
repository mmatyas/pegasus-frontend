{
  // ── CMake ──────────────────────────────────────────────────────────────────
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.configureOnOpen": false,
  "cmake.generator": "Unix Makefiles",
  "cmake.configureArgs": [
    "-DPEGASUS_USE_SDL2_GAMEPAD=ON",
    "-DPEGASUS_USE_SDL2_POWER=ON",
    "-DPEGASUS_ENABLE_APNG=OFF",
    "-DPEGASUS_ENABLE_LTO=OFF",
    "-DCMAKE_BUILD_TYPE=Debug"
  ],
  // Pass Qt prefix path discovered by the nix devshell (written to .vscode/.env)
  "cmake.cmakePath": "${env:CMAKE_PATH}",
  "cmake.configureEnvironment": {
    "CMAKE_PREFIX_PATH": "${env:CMAKE_PREFIX_PATH}",
    "Qt5_DIR": "${env:Qt5_DIR}"
  },
  "cmake.buildEnvironment": {
    "CMAKE_PREFIX_PATH": "${env:CMAKE_PREFIX_PATH}"
  },

  // ── C/C++ extension (ms-vscode.cpptools) ──────────────────────────────────
  // Include paths are populated from compile_commands.json generated by CMake.
  "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
  // Fallback include paths (active before the first cmake configure).
  // After `nix develop`, Qt5_DIR / QT_INCLUDE_PATH are set; these are
  // static placeholders – update if your Nix store path changes.
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/src",
    "${workspaceFolder}/thirdparty",
    "${env:QT_INCLUDE_PATH}",
    "${env:QT_INCLUDE_PATH}/QtCore",
    "${env:QT_INCLUDE_PATH}/QtGui",
    "${env:QT_INCLUDE_PATH}/QtQml",
    "${env:QT_INCLUDE_PATH}/QtQuick",
    "${env:QT_INCLUDE_PATH}/QtMultimedia",
    "${env:QT_INCLUDE_PATH}/QtSvg",
    "${env:QT_INCLUDE_PATH}/QtSql",
    "${env:QT_INCLUDE_PATH}/QtNetwork",
    "${env:QT_INCLUDE_PATH}/QtWidgets",
    "${env:SDL2_INCLUDE}",
    "${env:SQLITE_INCLUDE}"
  ],

  // ── clangd (optional, preferred over cpptools for larger projects) ─────────
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build",
    "--background-index",
    "--clang-tidy",
    "--header-insertion=never",
    "--completion-style=detailed"
  ],

  // ── dotenv – load the .env written by the nix devshell shellHook ──────────
  // Requires the "mikestead.dotenv" extension or VS Code built-in envFile support.
  "terminal.integrated.env.linux": {
    "ENV_FILE": "${workspaceFolder}/.vscode/.env"
  },

  // ── Editor ergonomics ──────────────────────────────────────────────────────
  "editor.formatOnSave": false,
  "files.associations": {
    "*.qml": "qml",
    "*.pri": "cmake",
    "*.pro": "cmake"
  },
  "files.exclude": {
    "build/": true,
    "**/*.qm": true
  }
}
